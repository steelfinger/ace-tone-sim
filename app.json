{
  "expo": {
    "name": "Rhythm Ace",
    "slug": "ace-tone-sim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3a2418"
    },
    "ios": {
      "deploymentTarget": "16.0",
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "fi.steelfinger.rhythmace",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Rhythm Ace uses the microphone API required by the audio engine. The app does not record audio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3a2418"
      },
      "package": "fi.steelfinger.rhythmace"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "668b49b2-cabe-4235-ab2d-24a5ad56969e"
      }
    }
  }
}
